{
  "layout": {
    "type": "layout",
    "pages": ["main-page", "actions-page"],
    "main-page": {
      "type": "page",
      "title": "History-Dispatcher",
      "sections": ["runtime-section", "display-section"]
    },
    "actions-page": {
      "type": "page",
      "title": "Actions",
      "sections": ["actions-section"]
    },
    "runtime-section": {
      "type": "section",
      "title": "Runtime",
      "keys": [
        "config-path",
        "runtime-path",
        "command-path",
        "refresh-seconds",
        "auto-refresh",
        "log-level",
        "status-heartbeat-seconds",
        "collector-enabled",
        "collector-interval-seconds",
        "collector-scan-limit",
        "dispatch-enabled",
        "dispatch-paused",
        "dispatch-batch-size",
        "claim-ttl-seconds",
        "max-attempts",
        "completed-retention-days",
        "audit-retention-days"
      ]
    },
    "display-section": {
      "type": "section",
      "title": "Display",
      "keys": ["show-collector", "show-queue", "show-dispatch", "max-lines"]
    },
    "actions-section": {
      "type": "section",
      "title": "Allowlisted actions",
      "keys": ["enable-actions", "confirm-actions"]
    }
  },
  "config-path": {
    "type": "entry",
    "description": "History-Dispatcher config.toml path",
    "default": "/home/teladi/.config/history-dispatcher/config.toml"
  },
  "runtime-path": {
    "type": "entry",
    "description": "History-Dispatcher runtime directory",
    "default": "/run/user/1000/history-dispatcher"
  },
  "command-path": {
    "type": "entry",
    "description": "History-Dispatcher executable",
    "default": "/home/teladi/History-Dispatcher/.venv-py313/bin/history-dispatcher"
  },
  "refresh-seconds": {
    "type": "spinbutton",
    "description": "Refresh interval in seconds",
    "min": 5,
    "max": 3600,
    "step": 5,
    "default": 30
  },
  "auto-refresh": {
    "type": "switch",
    "description": "Refresh automatically",
    "default": true
  },
  "log-level": {
    "type": "combobox",
    "description": "Service log level",
    "options": {"Debug": "DEBUG", "Info": "INFO", "Warning": "WARNING", "Error": "ERROR", "Critical": "CRITICAL"},
    "default": "INFO"
  },
  "status-heartbeat-seconds": {
    "type": "spinbutton",
    "description": "Status heartbeat in seconds",
    "min": 1,
    "max": 3600,
    "step": 1,
    "default": 30
  },
  "collector-enabled": {
    "type": "switch",
    "description": "Enable Codex collector",
    "default": true
  },
  "collector-interval-seconds": {
    "type": "spinbutton",
    "description": "Collector interval in seconds",
    "min": 60,
    "max": 86400,
    "step": 60,
    "default": 300
  },
  "collector-scan-limit": {
    "type": "spinbutton",
    "description": "Maximum source files per collection",
    "min": 1,
    "max": 10000,
    "step": 1,
    "default": 25
  },
  "dispatch-enabled": {
    "type": "switch",
    "description": "Enable dispatch worker",
    "default": true
  },
  "dispatch-paused": {
    "type": "switch",
    "description": "Pause dispatch",
    "default": false
  },
  "dispatch-batch-size": {
    "type": "spinbutton",
    "description": "Dispatch batch size",
    "min": 1,
    "max": 1000,
    "step": 1,
    "default": 20
  },
  "claim-ttl-seconds": {
    "type": "spinbutton",
    "description": "Claim lease lifetime in seconds",
    "min": 1,
    "max": 604800,
    "step": 1,
    "default": 900
  },
  "max-attempts": {
    "type": "spinbutton",
    "description": "Maximum automatic attempts",
    "min": 1,
    "max": 1000,
    "step": 1,
    "default": 12
  },
  "completed-retention-days": {
    "type": "spinbutton",
    "description": "Completed history retention in days",
    "min": 1,
    "max": 3650,
    "step": 1,
    "default": 30
  },
  "audit-retention-days": {
    "type": "spinbutton",
    "description": "Audit/tombstone retention in days",
    "min": 1,
    "max": 3650,
    "step": 1,
    "default": 365
  },
  "show-collector": {
    "type": "switch",
    "description": "Show collector details",
    "default": true
  },
  "show-queue": {
    "type": "switch",
    "description": "Show queue details",
    "default": true
  },
  "show-dispatch": {
    "type": "switch",
    "description": "Show dispatch details",
    "default": true
  },
  "max-lines": {
    "type": "spinbutton",
    "description": "Maximum detail lines",
    "min": 5,
    "max": 100,
    "step": 5,
    "default": 20
  },
  "enable-actions": {
    "type": "switch",
    "description": "Enable allowlisted actions",
    "default": true
  },
  "confirm-actions": {
    "type": "switch",
    "description": "Confirm mutating actions",
    "default": true
  }
}
